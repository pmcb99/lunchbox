# Lunchbox Configuration Template
# Copy this file to .env and update with your actual values

# Required: Your Lunchbox API key
LUNCHBOX_API_KEY=lbk_live_your_api_key_here

# Optional: Lunchbox endpoint (if self-hosting)
LUNCHBOX_URL=https://lunchbox.dev

# Optional: Custom timeout for large databases
LUNCHBOX_TIMEOUT_SECONDS=1200

# Optional: Enable gzip compression
LUNCHBOX_COMPRESS_GZIP=true

# Optional: Custom temp directory
LUNCHBOX_TEMP_DIR=./.lunchbox/tmp

# Optional: Upload concurrency
LUNCHBOX_PARALLEL_UPLOADS=4

# PostgreSQL configuration (if testing both databases)
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_password
# PGDATABASE=test_db